---
const currentYear = new Date().getFullYear();
---

<footer class="bg-text text-white" role="contentinfo">
  <div class="container mx-auto px-4 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">

      <!-- Brand -->
      <div class="flex flex-col items-center md:items-start text-center md:text-left">
        <div class="flex items-center space-x-3 mb-3">
          <img src="/images/Logo.png" alt="" width="40" height="40" loading="lazy" class="h-10 w-auto" aria-hidden="true" />
          <span class="font-bold text-lg text-white">EoEPPS 2026</span>
        </div>
        <p class="text-gray-400 text-sm mb-2">
          1st &amp; 2nd May 2026 &bull; Norwich, Norfolk
        </p>
        <p class="text-gray-400 text-sm mb-4">
          Organised by the <a href="https://www.nppug.co.uk" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-white underline transition-colors">Norfolk Power Platform User Group</a>
        </p>
        <a
          href="https://www.linkedin.com/company/eoepps/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-white transition-colors"
          aria-label="Follow EoEPPS on LinkedIn (opens in new tab)"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
      </div>

      <!-- Site links -->
      <nav aria-label="Footer navigation">
        <p class="text-white font-semibold text-sm uppercase tracking-wide mb-3">Site</p>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-gray-400 hover:text-white transition-colors">Home</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-white transition-colors">About</a></li>
          <li><a href="/workshops" class="text-gray-400 hover:text-white transition-colors">Workshops</a></li>
          <li><a href="/schedule" class="text-gray-400 hover:text-white transition-colors">Schedule</a></li>
          <li><a href="/speakers" class="text-gray-400 hover:text-white transition-colors">Speakers</a></li>
          <li><a href="/sponsors" class="text-gray-400 hover:text-white transition-colors">Sponsors</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </nav>

      <!-- Attend links -->
      <div>
        <p class="text-white font-semibold text-sm uppercase tracking-wide mb-3">Attend</p>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="https://eoeppstickets.netlify.app" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors">
              Get Your Free Ticket<span class="sr-only"> (opens in new tab)</span>
            </a>
          </li>
          <li>
            <a href="/sponsorship" class="text-gray-400 hover:text-white transition-colors">Become a Sponsor</a>
          </li>
          <li>
            <a href="/venue" class="text-gray-400 hover:text-white transition-colors">Venue &amp; Travel</a>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/10 pt-6 text-center">
      <p class="text-gray-400 text-sm">&copy; {currentYear} East of England Power Platform Summit</p>
    </div>
  </div>
</footer>
