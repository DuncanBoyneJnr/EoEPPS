---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout
  title="Home"
  description="EoEPPS 2026 — the East of England's Power Platform Summit. Two days of hands-on workshops and expert sessions covering Power Apps, Power Automate, Power BI, and Copilot Studio. Norwich, 1–2 May 2026. Conference day is free to attend."
>

  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-primary via-primary-dark to-accent text-white py-24 md:py-36 overflow-hidden">
    <!-- Ambient glow orbs -->
    <div class="absolute -top-40 -right-40 w-[28rem] h-[28rem] rounded-full bg-secondary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute -bottom-40 -left-40 w-[28rem] h-[28rem] rounded-full bg-accent/15 blur-3xl pointer-events-none" aria-hidden="true"></div>

    <div class="relative container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Right: Logos — stacked on desktop, inline on mobile -->
        <div class="flex flex-col items-center gap-6 lg:order-2">
          <!-- Main logo with glow -->
          <div class="relative">
            <div class="absolute inset-0 bg-white/10 rounded-full blur-3xl scale-125" aria-hidden="true"></div>
            <img src="/images/Logo.png" alt="EoEPPS Logo" width="320" height="320" class="relative w-48 sm:w-60 lg:w-72 h-auto drop-shadow-2xl" />
          </div>
        </div>

        <!-- Left: Text -->
        <div class="text-center lg:text-left lg:order-1">
          <!-- Date pill -->
          <div class="inline-flex items-center gap-2 bg-secondary text-gray-900 rounded-full px-4 py-1.5 text-sm font-bold mb-7 uppercase tracking-wider">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M5.75 2a.75.75 0 0 1 .75.75V4h7V2.75a.75.75 0 0 1 1.5 0V4h.25A2.75 2.75 0 0 1 18 6.75v8.5A2.75 2.75 0 0 1 15.25 18H4.75A2.75 2.75 0 0 1 2 15.25v-8.5A2.75 2.75 0 0 1 4.75 4H5V2.75A.75.75 0 0 1 5.75 2Zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75Z" clip-rule="evenodd" />
            </svg>
            1st &amp; 2nd May 2026 &bull; Norwich, Norfolk
          </div>

          <!-- Big display headline -->
          <h1 class="text-5xl md:text-7xl font-extrabold leading-[0.95] tracking-tight mb-6">
            East of England<br />
            <span class="text-secondary">Power Platform</span><br />
            Summit
          </h1>

          <p class="text-lg md:text-xl text-white/80 mb-6 max-w-xl mx-auto lg:mx-0 leading-relaxed">
            The East of England's flagship Power Platform conference. Two days of sessions, workshops, and networking.
          </p>

          <!-- Venue Change Notice -->
          <div class="relative mb-8 max-w-xl mx-auto lg:mx-0 rounded-2xl overflow-hidden border-2 border-secondary shadow-lg shadow-secondary/20">
            <div class="bg-secondary px-4 py-2 flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-900 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 5zm0 9a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-900 font-black text-sm uppercase tracking-widest">Venue Update</span>
            </div>
            <div class="bg-gray-900/80 backdrop-blur-sm px-5 py-4">
              <p class="text-white font-bold text-base mb-2">Both days are now at the same venue:</p>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-secondary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <address class="not-italic text-white/90 text-sm leading-relaxed">
                  <strong class="text-secondary text-base block">The Digital Hub</strong>
                  Townshend House<br />
                  30 Crown Road<br />
                  Norwich, NR1 3DT
                </address>
              </div>
            </div>
          </div>

          <!-- Badges -->
          <div class="flex flex-wrap gap-3 justify-center lg:justify-start mb-8">
            <span class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-white font-semibold text-sm backdrop-blur-sm">
              Conference Day — <span class="text-secondary font-bold">FREE</span>
            </span>
            <span class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-xl px-4 py-2 text-white font-semibold text-sm backdrop-blur-sm">
              <svg class="w-4 h-4 text-secondary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
              Workshops from <span class="text-secondary font-bold ml-1">£75</span>
            </span>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
            <a
              href="https://eoeppstickets.netlify.app"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-secondary text-gray-900 px-7 py-3.5 rounded-xl font-bold text-base hover:bg-secondary-light hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 shadow-lg"
            >
              Get Tickets<span class="sr-only"> (opens in new tab)</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            <a
              href="/speakers"
              class="inline-flex items-center justify-center gap-2 bg-white/10 border border-white/25 text-white px-7 py-3.5 rounded-xl font-bold text-base hover:bg-white/20 hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 backdrop-blur-sm"
            >
              Meet the Speakers
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- Free Ticket CTA -->
  <div class="bg-primary py-4">
    <div class="container mx-auto px-4 text-center">
      <a
        href="https://eoeppstickets.netlify.app"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-white font-bold text-base md:text-lg hover:text-secondary transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-secondary flex-shrink-0">
          <path fill-rule="evenodd" d="M16.403 12.652a3 3 0 0 0 0-5.304 3 3 0 0 0-3.75-3.751 3 3 0 0 0-5.305 0 3 3 0 0 0-3.751 3.75 3 3 0 0 0 0 5.305 3 3 0 0 0 3.75 3.751 3 3 0 0 0 5.305 0 3 3 0 0 0 3.751-3.75Zm-2.546-4.46a.75.75 0 0 0-1.214-.883l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" />
        </svg>
        Conference Day is FREE — get your ticket now<span class="sr-only"> (opens in new tab)</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>


  <!-- What to Expect -->
  <section class="py-24 md:py-32 bg-primary-dark">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">What to Expect</h2>
        <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-5" aria-hidden="true"></div>
        <p class="text-white/75 text-lg max-w-2xl mx-auto leading-relaxed">
          Two packed days of learning, sharing, and connecting with Power Platform professionals from across the East of England and beyond.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Card 01 -->
        <div class="relative bg-white p-7 rounded-2xl shadow-md overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <span class="absolute top-4 right-5 text-7xl font-black text-primary/10 leading-none select-none pointer-events-none" aria-hidden="true">01</span>
          <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">Hands-on Workshops</h3>
          <p class="text-text-light leading-relaxed">Day 1 is dedicated to practical, hands-on workshops. Get your hands dirty building real solutions — places from <strong class="text-text">£75</strong>.</p>
        </div>

        <!-- Card 02 -->
        <div class="relative bg-white p-7 rounded-2xl shadow-md overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <span class="absolute top-4 right-5 text-7xl font-black text-primary/10 leading-none select-none pointer-events-none" aria-hidden="true">02</span>
          <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">Expert Sessions</h3>
          <p class="text-text-light leading-relaxed">Day 2 features multiple tracks of conference sessions from community experts, Microsoft MVPs, and industry professionals.</p>
        </div>

        <!-- Card 03 -->
        <div class="relative bg-white p-7 rounded-2xl shadow-md overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <span class="absolute top-4 right-5 text-7xl font-black text-primary/10 leading-none select-none pointer-events-none" aria-hidden="true">03</span>
          <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">Networking</h3>
          <p class="text-text-light leading-relaxed">Connect with Power Platform professionals from across the region. Build relationships that go beyond the conference.</p>
        </div>

        <!-- Card 04 -->
        <div class="relative bg-white p-7 rounded-2xl shadow-md overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <span class="absolute top-4 right-5 text-7xl font-black text-secondary/15 leading-none select-none pointer-events-none" aria-hidden="true">04</span>
          <div class="w-14 h-14 bg-secondary/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">Multiple Tracks</h3>
          <p class="text-text-light leading-relaxed">Sessions covering Power Apps, Power Automate, Power BI, Power Pages, Copilot Studio, Dataverse, and more.</p>
        </div>

        <!-- Card 05 -->
        <div class="relative bg-white p-7 rounded-2xl shadow-md overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <span class="absolute top-4 right-5 text-7xl font-black text-secondary/15 leading-none select-none pointer-events-none" aria-hidden="true">05</span>
          <div class="w-14 h-14 bg-secondary/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">Exhibition Area</h3>
          <p class="text-text-light leading-relaxed">Explore an exhibition area with sponsors, partners, and vendors showcasing the latest in the Power Platform ecosystem.</p>
        </div>

        <!-- Card 06 -->
        <div class="relative bg-white p-7 rounded-2xl shadow-md overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
          <span class="absolute top-4 right-5 text-7xl font-black text-accent/15 leading-none select-none pointer-events-none" aria-hidden="true">06</span>
          <div class="w-14 h-14 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-2">Free Conference Day</h3>
          <p class="text-text-light leading-relaxed">Saturday's conference day is <strong class="text-text">completely free</strong> to attend. Friday workshops are ticketed from <strong class="text-text">£75</strong> — secure your place early.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Schedule Overview -->
  <section class="py-24 md:py-32">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">The Schedule</h2>
        <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-5" aria-hidden="true"></div>
        <p class="text-text-light text-lg max-w-2xl mx-auto">
          Two full days of Power Platform content in Norwich.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Day 1 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
          <div class="bg-primary text-white px-6 py-6">
            <div class="flex items-center justify-between mb-2">
              <div class="text-sm font-semibold text-white/90 uppercase tracking-wide">Friday 1st May 2026</div>
              <span class="bg-secondary text-gray-900 text-xs font-bold px-3 py-1 rounded-full">from £75</span>
            </div>
            <h3 class="text-2xl font-bold">Day 1: Workshop Day</h3>
            <div class="text-white/90 text-sm mt-1">9:00 AM – 4:30 PM</div>
          </div>
          <div class="p-6">
            <div class="flex items-start mb-4">
              <svg class="w-5 h-5 text-primary mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <div class="font-semibold text-text">The Digital Hub, Townshend House</div>
                <div class="text-text-light text-sm">30 Crown Road, Norwich NR1 3DT</div>
                <a href="https://share.google/0XFQL3ShPVJXjfstT" target="_blank" rel="noopener noreferrer" class="text-primary text-sm hover:underline">
                  View on Google Maps<span class="sr-only"> (opens in new tab)</span>
                </a>
              </div>
            </div>
            <p class="text-text-light mb-5 leading-relaxed">
              Hands-on practical workshops led by experts. Roll up your sleeves and build real solutions with Power Platform tools.
            </p>
            <a href="/schedule#day1" class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors">
              View Day 1 Schedule
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Day 2 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
          <div class="bg-accent text-white px-6 py-6">
            <div class="flex items-center justify-between mb-2">
              <div class="text-sm font-semibold text-white/90 uppercase tracking-wide">Saturday 2nd May 2026</div>
              <span class="bg-white text-accent text-xs font-bold px-3 py-1 rounded-full">FREE</span>
            </div>
            <h3 class="text-2xl font-bold">Day 2: Conference Day</h3>
            <div class="text-white/90 text-sm mt-1">8:00 AM – 5:30 PM</div>
          </div>
          <div class="p-6">
            <div class="flex items-start mb-4">
              <svg class="w-5 h-5 text-accent mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <div>
                <div class="font-semibold text-text">The Digital Hub, Townshend House</div>
                <div class="text-text-light text-sm">30 Crown Road, Norwich NR1 3DT</div>
                <a href="https://share.google/0XFQL3ShPVJXjfstT" target="_blank" rel="noopener noreferrer" class="text-accent text-sm hover:underline">
                  View on Google Maps<span class="sr-only"> (opens in new tab)</span>
                </a>
              </div>
            </div>
            <p class="text-text-light mb-5 leading-relaxed">
              A full day of conference sessions across multiple tracks. Keynotes, breakouts, and networking opportunities throughout the day.
            </p>
            <a href="/schedule#day2" class="inline-flex items-center text-accent font-semibold hover:text-accent/150 transition-colors">
              View Day 2 Schedule
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Where It's Happening -->
  <section class="py-24 md:py-32 bg-background-alt">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">Where It's Happening</h2>
        <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-5" aria-hidden="true"></div>
        <p class="text-text-light text-lg max-w-2xl mx-auto">
          Both days take place at the same venue in the heart of Norwich.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Venue 1 -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300">
          <div class="bg-primary px-6 py-5 text-white">
            <div class="text-sm font-semibold text-white/70 mb-1 uppercase tracking-wide">Day 1 &bull; Friday 1st May</div>
            <h3 class="text-xl font-bold">The Digital Hub, Townshend House</h3>
          </div>
          <div class="p-6">
            <p class="text-text-light mb-4 leading-relaxed">
              A modern conference and events space in central Norwich, Townshend House is the perfect setting for Day 1's hands-on workshops. With dedicated workshop rooms and great transport links, it's easy to get to and a great place to learn.
            </p>
            <div class="flex items-start text-sm text-text-light mb-5">
