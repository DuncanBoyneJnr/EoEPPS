          <table class="w-full text-sm min-w-[860px]">
            <thead>
              <tr>
                <th class="text-left py-5 px-5 bg-primary/5 font-semibold text-text border-b border-primary/20">Benefit</th>
                <th class="py-5 px-3 bg-primary/60 text-white font-semibold text-center border-b border-primary/20 w-24">
                  <div class="text-white/70 text-xs uppercase tracking-wider mb-1">Friend</div>
                  <div class="text-xl font-bold">£250</div>
                </th>
                <th class="py-5 px-3 bg-primary text-white font-semibold text-center border-b border-primary/20 w-24">
