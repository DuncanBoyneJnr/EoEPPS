---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="East of England Power Platform Summit 2026 - 1st & 2nd May 2026, Norwich, Norfolk." />
    <link rel="icon" type="image/png" href="/images/Logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
    <title>East of England Power Platform Summit 2026</title>
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center bg-gradient-to-br from-primary via-primary-dark to-accent font-['Plus_Jakarta_Sans',sans-serif]">

    <div class="flex flex-col items-center gap-8 text-center px-4">

      <!-- Logo -->
      <img
        src="/images/Logo.png"
        alt="EoEPPS Logo"
        width="320"
        height="320"
        class="w-48 sm:w-64 h-auto drop-shadow-2xl"
      />

      <!-- Message -->
      <p class="text-white/90 text-2xl sm:text-3xl font-semibold">
        Currently Under Maintenance
      </p>

      <!-- Tickets button -->
      <a
        href="https://eoeppstickets.netlify.app/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-secondary text-primary-dark font-bold text-lg px-8 py-4 rounded-xl shadow-lg hover:brightness-110 transition"
      >
        Get Tickets
      </a>

    </div>

  </body>
</html>
