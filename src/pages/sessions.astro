---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

// Fetch room assignments from GridSmart at build time
const gridRes = await fetch('https://sessionize.com/api/v2/9q20ek5l/view/GridSmart?under=True', {
  headers: { 'User-Agent': 'Mozilla/5.0' }
});
const gridHtml = await gridRes.text();

// Map: sessionId -> trackId
const roomMap: Record<string, string> = {};
for (const m of gridHtml.matchAll(/data-sessionid="(\d+)"[^>]*grid-column[^"]*track-(\d+)/g)) {
  roomMap[m[1]] = m[2];
}

const rooms = [
  { id: '74435', label: 'The Auditorium' },
  { id: '74437', label: 'The Blue Space' },
  { id: '78123', label: 'The Orange Space' },
  { id: '74436', label: 'The Yellow Space' },
];

const roomMapJson = JSON.stringify(roomMap);
---

<BaseLayout title="Sessions" description="Browse and filter all sessions at the East of England Power Platform Summit 2026 – 2nd May 2026, Norwich.">
  <Hero
    title="Sessions"
    subtitle="31 sessions across 4 tracks at EoEPPS 2026."
  />

  <!-- Filters -->
  <div class="sticky top-[64px] z-40 bg-white border-b border-border shadow-sm">
    <div class="container mx-auto px-4 py-4 space-y-3">

      <!-- Row 1: Track + Level -->
      <div class="flex flex-col sm:flex-row gap-3 sm:items-center sm:justify-between">
        <!-- Track filter -->
        <div class="flex flex-wrap gap-2 items-center">
          <span class="text-xs font-semibold text-text-light uppercase tracking-widest mr-1 whitespace-nowrap">Track</span>
          <button class="filter-btn filter-track active" data-track="all">All</button>
          <button class="filter-btn filter-track" data-track="sz-tag_113750-409150">Technical</button>
          <button class="filter-btn filter-track" data-track="sz-tag_113750-409151">Business Adoption</button>
          <button class="filter-btn filter-track" data-track="sz-tag_113750-409148">Non-Technical</button>
          <button class="filter-btn filter-track" data-track="sz-tag_113750-409149">New Speaker</button>
        </div>

        <!-- Level filter -->
        <div class="flex flex-wrap gap-2 items-center">
          <span class="text-xs font-semibold text-text-light uppercase tracking-widest mr-1 whitespace-nowrap">Level</span>
          <button class="filter-btn filter-level active" data-level="all">All</button>
          <button class="filter-btn filter-level" data-level="sz-tag_113748-409142">100</button>
          <button class="filter-btn filter-level" data-level="sz-tag_113748-409143">200</button>
          <button class="filter-btn filter-level" data-level="sz-tag_113748-409144">300</button>
          <button class="filter-btn filter-level" data-level="sz-tag_113748-409145">400</button>
        </div>
      </div>

      <!-- Row 2: Room filter -->
      <div class="flex flex-wrap gap-2 items-center">
        <span class="text-xs font-semibold text-text-light uppercase tracking-widest mr-1 whitespace-nowrap">Room</span>
        <button class="filter-btn filter-room active" data-room="all">All Rooms</button>
        {rooms.map(r => (
          <button class="filter-btn filter-room" data-room={r.id}>{r.label}</button>
        ))}
      </div>

      <!-- Session count -->
      <p class="text-xs text-text-light" id="session-count" aria-live="polite">Loading sessions…</p>
    </div>
  </div>

  <!-- Sessionize Sessions embed -->
  <section class="py-10 md:py-14 bg-background-alt">
    <div class="container mx-auto px-4">
      <link rel="stylesheet" href="https://sessionize.com/api/v2/9q20ek5l/embedstyle" />
      <div id="sessions-embed-wrapper">
        <script is:inline src="https://sessionize.com/api/v2/9q20ek5l/view/Sessions"></script>
      </div>
    </div>
  </section>

  <!-- Modal container required by Sessionize -->
  <div id="sz-modal-container" class="is-hidden"></div>

  <!-- CTA -->
  <section class="relative py-16 bg-primary text-white overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-secondary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="relative container mx-auto px-4 text-center">
      <h2 class="text-3xl font-extrabold mb-3 tracking-tight">Ready to Join Us?</h2>
      <p class="text-white/80 mb-8 max-w-xl mx-auto">
        Day 2 (the conference day) is free to attend. Grab your spot before they're gone.
      </p>
      <a
        href="https://eoeppstickets.netlify.app"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-secondary text-gray-900 px-8 py-3.5 rounded-xl font-bold text-lg hover:bg-secondary-light hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 shadow-lg"
      >
        Get Free Tickets<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .filter-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    background: #f1f5f9;
    color: #64748b;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .filter-btn:hover:not(.active) {
    background: #e2e8f0;
    color: #334155;
  }
  .filter-btn:focus-visible {
    outline: 2px solid #5B21B6;
    outline-offset: 2px;
  }
  .filter-btn.active {
    background: #5B21B6;
    color: #fff;
    border-color: #5B21B6;
  }

  /* ── Sessionize brand overrides ── */
  .sz-session__title { color: #1e1b4b; }
  .sz-session a { color: #5B21B6; }

  .sz-sessions--list {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)) !important;
    gap: 1.25rem !important;
    align-items: stretch !important;
  }
  .sz-session {
    background: #fff !important;
    border-radius: 1rem !important;
    padding: 1.25rem 1.5rem !important;
    box-shadow: 0 1px 3px rgba(0,0,0,.08), 0 4px 16px rgba(91,33,182,.06) !important;
    transition: box-shadow .2s, transform .2s !important;
    border: 1px solid #f0edf8 !important;
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
    box-sizing: border-box !important;
    margin: 0 !important;
  }
  .sz-session:hover { box-shadow: 0 4px 24px rgba(91,33,182,.12) !important; transform: translateY(-2px) !important; }
  .sz-session__title { font-size: 1rem; font-weight: 700; line-height: 1.35; margin: 0.5rem 0 0.75rem; }
  .sz-session__speakers { list-style: none; padding: 0; margin: 0 0 0.75rem; display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .sz-session__speakers li:not(:last-child)::after { content: ',\00a0'; }
  .sz-session__speakers a { font-size: 0.875rem; font-weight: 600; color: #5B21B6; text-decoration: none; }
  .sz-session__speakers a:hover { text-decoration: underline; }
  .sz-session__description { display: none; }
  .sz-tags { list-style: none; padding: 0; margin: 0.75rem 0 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .sz-tag { font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.6rem; border-radius: 99px; }

  /* Track tag colours */
  .sz-tag_113750-409150 { background: #ede9fe; color: #5B21B6; }
  .sz-tag_113750-409151 { background: #fef3c7; color: #92400e; }
  .sz-tag_113750-409148 { background: #fce7f3; color: #9d174d; }
  .sz-tag_113750-409149 { background: #ecfdf5; color: #065f46; }

  /* Level chips */
  .sz-tag_113748-409142 { background: #f1f5f9; color: #475569; }
  .sz-tag_113748-409143 { background: #dbeafe; color: #1e40af; }
  .sz-tag_113748-409144 { background: #fde68a; color: #92400e; }
  .sz-tag_113748-409145 { background: #fee2e2; color: #991b1b; }

  /* Duration chip */
  .sz-tag_113832-409384,
  .sz-tag_113832-409385,
  .sz-tag_113832-409386 { background: #f8fafc; color: #64748b; }

  .sz-spinner { background-color: #5B21B6 !important; }
  .sz-session--filtered { display: none !important; }

  /* Clickable card cursor */
  .sz-session { cursor: pointer; }
  .sz-session__view-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #5B21B6;
  }

  /* ── Modal overlay ── */
  #sz-modal-container {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  #sz-modal-container.is-hidden { display: none !important; }

  .sz-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 10, 30, 0.65);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .sz-modal-container-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 640px;
    max-height: 90vh;
    overflow-y: auto;
    border-radius: 1.25rem;
    background: #fff;
    box-shadow: 0 25px 60px rgba(91, 33, 182, 0.2), 0 8px 20px rgba(0,0,0,0.15);
    scrollbar-width: thin;
  }

  .sz-modal {
    position: relative;
    padding: 2rem;
  }

  /* ── Close button ── */
  .sz-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    background: #f1f5f9;
    border: none;
    cursor: pointer;
    font-size: 0.875rem;
    color: #64748b;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s;
    line-height: 1;
  }
  .sz-modal__close:hover { background: #fee2e2; color: #991b1b; }

  /* ── Session modal ── */
  .sz-modal-session .sz-session {
    background: transparent;
    border: none;
    box-shadow: none;
    padding: 0;
    cursor: default;
    border-radius: 0;
    transform: none !important;
  }
  .sz-modal-session .sz-session:hover { box-shadow: none; transform: none; }

  /* Speakers row at top */
  .sz-modal-session .sz-session__speakers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }
  .sz-modal-session .sz-session__speakers li { display: flex; }
  .sz-modal-session .sz-session__speakers li::after { display: none; }
  .sz-modal-session .sz-session__speakers a {
    font-size: 0.8rem;
    font-weight: 700;
    color: #5B21B6;
    background: #ede9fe;
    padding: 0.2rem 0.65rem;
    border-radius: 9999px;
    text-decoration: none;
  }
  .sz-modal-session .sz-session__speakers a:hover { background: #ddd6fe; }

  /* Title */
  .sz-modal-session .sz-session__title {
    font-size: 1.35rem;
    font-weight: 800;
    line-height: 1.25;
    color: #1e1b4b;
    margin: 0 0 1.25rem;
  }

  /* Meta row: room + time */
  .sz-modal-session .sz-session__room,
  .sz-modal-session .sz-session__time {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 600;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 9999px;
    padding: 0.25rem 0.75rem;
    margin: 0 0.4rem 0.75rem 0;
    color: #475569;
  }

  /* Description */
  .sz-modal-session .sz-session__description {
    display: block;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #374151;
    margin: 1rem 0;
    white-space: pre-line;
  }

  /* Tags */
  .sz-modal-session .sz-session__tags {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
  }

  /* ── Speaker modal ── */
  .sz-modal-speaker .sz-speaker--full {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .sz-modal-speaker .sz-speaker__photo {
    width: 100px;
    height: 100px;
    border-radius: 9999px;
    overflow: hidden;
    margin-bottom: 1rem;
    border: 3px solid #ede9fe;
    flex-shrink: 0;
  }
  .sz-modal-speaker .sz-speaker__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sz-modal-speaker .sz-speaker__name {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1e1b4b;
    margin: 0 0 0.35rem;
  }

  .sz-modal-speaker .sz-speaker__tagline {
    font-size: 0.8rem;
    color: #64748b;
    font-weight: 500;
    margin: 0 0 1rem;
    max-width: 480px;
    line-height: 1.4;
  }

  .sz-modal-speaker .sz-speaker__links {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    gap: 0.5rem;
    justify-content: center;
  }
  .sz-modal-speaker .sz-speaker__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #5B21B6;
    background: #ede9fe;
    padding: 0.3rem 0.75rem;
    border-radius: 9999px;
    text-decoration: none;
  }
  .sz-modal-speaker .sz-speaker__link:hover { background: #ddd6fe; }
  .sz-modal-speaker .sz-speaker__link-icon { width: 1rem; height: 1rem; }

  .sz-modal-speaker .sz-speaker__bio {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #374151;
    text-align: left;
    padding-top: 1rem;
    border-top: 1px solid #f1f5f9;
    width: 100%;
    margin: 0 0 1rem;
  }

  .sz-modal-speaker .sz-speaker__sessions {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    border-top: 1px solid #f1f5f9;
    padding-top: 1rem;
  }
  .sz-modal-speaker .sz-speaker__sessions li { margin-bottom: 0.4rem; }
  .sz-modal-speaker .sz-speaker__sessions a {
    font-size: 0.85rem;
    font-weight: 600;
    color: #5B21B6;
    text-decoration: none;
  }
  .sz-modal-speaker .sz-speaker__sessions a:hover { text-decoration: underline; }
</style>

<script is:inline define:vars={{ roomMapJson }}>
  (function () {
    var roomMap = JSON.parse(roomMapJson);
    var activeTrack = 'all';
    var activeLevel = 'all';
    var activeRoom  = 'all';

    function applyFilters() {
      var sessions = document.querySelectorAll('li.sz-session');
      var visible = 0;
      sessions.forEach(function (el) {
        var id = el.getAttribute('data-sessionid');
        var trackOk = activeTrack === 'all' || el.classList.contains(activeTrack);
        var levelOk = activeLevel === 'all' || el.classList.contains(activeLevel);
        var roomOk  = activeRoom  === 'all' || roomMap[id] === activeRoom;
        var show = trackOk && levelOk && roomOk;
        el.classList.toggle('sz-session--filtered', !show);
        if (show) visible++;
      });
      var countEl = document.getElementById('session-count');
      if (countEl) {
        countEl.textContent = 'Showing ' + visible + ' of ' + sessions.length + ' sessions';
      }
    }

    function bindGroup(selector, stateKey) {
      document.querySelectorAll(selector).forEach(function (btn) {
        btn.addEventListener('click', function () {
          document.querySelectorAll(selector).forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
          var val = btn.getAttribute('data-' + stateKey) || 'all';
          if (stateKey === 'track') activeTrack = val;
          else if (stateKey === 'level') activeLevel = val;
          else if (stateKey === 'room')  activeRoom  = val;
          applyFilters();
        });
      });
    }

    function makeCardsClickable() {
      document.querySelectorAll('li.sz-session').forEach(function (card) {
        // Add "View details" hint if not already added
        if (!card.querySelector('.sz-session__view-hint')) {
          var hint = document.createElement('span');
          hint.className = 'sz-session__view-hint';
          hint.innerHTML = 'View details &rarr;';
          card.appendChild(hint);
        }
        // Click anywhere on card (except speaker links) opens session modal
        card.addEventListener('click', function (e) {
          if (e.target.closest('a')) return; // let speaker links handle themselves
          var id = card.getAttribute('data-sessionid');
          if (id && window.sessionize) {
            window.sessionize.showModal('9q20ek5l', 'session', id);
          }
        });
      });
    }

    function watchForSessions() {
      var wrapper = document.getElementById('sessions-embed-wrapper');
      if (!wrapper) return;
      var observer = new MutationObserver(function (_, obs) {
        if (document.querySelectorAll('li.sz-session').length > 0) {
          obs.disconnect();
          applyFilters();
          makeCardsClickable();
        }
      });
      observer.observe(wrapper, { childList: true, subtree: true });
      if (document.querySelectorAll('li.sz-session').length > 0) {
        observer.disconnect();
        applyFilters();
        makeCardsClickable();
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      bindGroup('.filter-track', 'track');
      bindGroup('.filter-level', 'level');
      bindGroup('.filter-room',  'room');
      watchForSessions();
    });
  })();
</script>
