---
const featuredSponsors = [
  {
    name: 'Untethered 365',
    logo: '/images/sponsors/Untethered365.png',
    href: 'https://www.untethered365.com/freetraining?utm_source=conference&utm_medium=conference&utm_content=norfolk-summit',
    bgColor: '#0d1b35',
  },
];

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/why-attend', label: 'Why Attend' },
  { href: '/workshops', label: 'Workshops' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/sessions', label: 'Sessions' },
  { href: '/speakers', label: 'Speakers' },
  {
    label: 'Sponsors',
    href: '/sponsors',
    children: [
      { href: '/sponsors', label: 'Our Sponsors' },
      { href: '/sponsorship', label: 'Become a Sponsor' },
    ]
  },
  { href: '/contact', label: 'Contact' },
];

const allLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/why-attend', label: 'Why Attend' },
  { href: '/workshops', label: 'Workshops' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/sessions', label: 'Sessions' },
  { href: '/speakers', label: 'Speakers' },
  { href: '/sponsors', label: 'Our Sponsors' },
  { href: '/sponsorship', label: 'Become a Sponsor' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-primary text-white shadow-lg sticky top-0 z-50" role="banner">
  <nav class="container mx-auto px-4 py-3" role="navigation" aria-label="Main navigation">
    <!-- Desktop Navigation -->
    <div class="hidden lg:flex items-center justify-between">
      <!-- Logo + Featured Sponsor -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <a href="/" class="hover:opacity-90 transition-opacity flex items-center">
          <img src="/images/Logo.png" alt="East of England Power Platform Summit 2026" width="40" height="40" class="h-10 w-auto" />
        </a>
        <div class="border-l border-white/25 pl-3 flex flex-col justify-center">
          <span class="text-white/55 text-[9px] font-bold uppercase tracking-widest leading-none mb-1">Featured Sponsor</span>
          <a
            id="featured-sponsor-link"
            href={featuredSponsors[0].href}
            target="_blank"
            rel="noopener noreferrer"
            class="block hover:opacity-80 transition-opacity"
            aria-label={`Featured Sponsor: ${featuredSponsors[0].name} (opens in new tab)`}
          >
            <div class="h-7 px-2 rounded flex items-center justify-center" style={`background-color: ${featuredSponsors[0].bgColor}`}>
              <img
                id="featured-sponsor-img"
                src={featuredSponsors[0].logo}
                alt={featuredSponsors[0].name}
                class="h-5 w-auto max-w-[100px] object-contain"
              />
            </div>
          </a>
        </div>
      </div>

      <!-- All Navigation Links -->
      <div class="flex items-center space-x-1">
        {navLinks.map((link) => (
          link.children ? (
            <div class="relative group">
              <a
                href={link.href}
                class:list={[
                  'px-4 py-2 rounded-lg transition-colors h-10 flex items-center',
                  currentPath === link.href || currentPath.startsWith(link.href + '/') || link.children?.some((c: {href: string}) => currentPath === c.href)
                    ? 'bg-white/20 font-semibold'
                    : 'hover:bg-white/10',
                ]}
              >
                {link.label}
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </a>
              <div class="absolute left-0 mt-1 w-52 bg-white rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible transition-all duration-200 z-50">
                {link.children.map((child) => (
                  <a
                    href={child.href}
                    class:list={[
                      'block px-4 py-2 text-text hover:bg-background-alt transition-colors first:rounded-t-lg last:rounded-b-lg',
                      currentPath === child.href || currentPath.startsWith(child.href + '/') ? 'bg-primary/10 text-primary font-semibold' : '',
                    ]}
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class:list={[
                'px-4 py-2 rounded-lg transition-colors h-10 flex items-center',
                currentPath === link.href
                  ? 'bg-white/20 font-semibold'
                  : 'hover:bg-white/10',
              ]}
            >
              {link.label}
            </a>
          )
        ))}
      </div>

      <!-- Get Tickets CTA -->
      <a
        href="https://eoeppstickets.netlify.app"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-4 flex-shrink-0 inline-block bg-secondary text-primary px-4 py-2 rounded-lg font-bold text-sm hover:bg-secondary-light transition-colors"
      >
        Get Tickets<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>

    <!-- Mobile: Logo and Menu Button -->
    <div class="flex lg:hidden items-center justify-between">
      <a href="/" class="hover:opacity-90 transition-opacity">
        <img src="/images/Logo.png" alt="East of England Power Platform Summit 2026" width="40" height="40" class="h-10 w-auto" />
      </a>

      <button
        id="mobile-menu-button"
        class="p-2 rounded-lg hover:bg-white/10 transition-colors"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-white/20 pt-4">
      <a
        href="https://eoeppstickets.netlify.app"
        target="_blank"
        rel="noopener noreferrer"
        class="block mx-4 mb-3 text-center bg-secondary text-primary px-4 py-2 rounded-lg font-bold hover:bg-secondary-light transition-colors"
      >
        Get Tickets<span class="sr-only"> (opens in new tab)</span>
      </a>
      {allLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-2 rounded-lg transition-colors text-center',
            currentPath === link.href
              ? 'bg-white/20 font-semibold'
              : 'hover:bg-white/10',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  // Featured sponsor rotation
  const sponsors = [
    {
      name: 'Untethered 365',
      logo: '/images/sponsors/Untethered365.png',
      href: 'https://www.untethered365.com/freetraining?utm_source=conference&utm_medium=conference&utm_content=norfolk-summit',
      bgColor: '#0d1b35',
    },
  ];

  if (sponsors.length > 1) {
    let current = 0;
    const link = document.getElementById('featured-sponsor-link') as HTMLAnchorElement | null;
    const img = document.getElementById('featured-sponsor-img') as HTMLImageElement | null;

    setInterval(() => {
      current = (current + 1) % sponsors.length;
      const s = sponsors[current];
      if (link) {
        link.href = s.href;
        link.setAttribute('aria-label', `Featured Sponsor: ${s.name} (opens in new tab)`);
        const bg = link.querySelector('div') as HTMLElement | null;
        if (bg) bg.style.backgroundColor = s.bgColor;
      }
      if (img) {
        img.src = s.logo;
        img.alt = s.name;
      }
    }, 8000);
  }

  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  menuButton?.addEventListener('click', () => {
    const isExpanded = menuButton.getAttribute('aria-expanded') === 'true';
    menuButton.setAttribute('aria-expanded', (!isExpanded).toString());
    mobileMenu?.classList.toggle('hidden');
  });
</script>
