                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
              </tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Logo on event roller banners throughout the venue</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
              </tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Headline logo placement alongside EoEPPS branding</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
              </tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Exclusive branding on attendee lanyards</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
              </tr>

              <tr><td colspan="6" class="py-2 px-5 bg-primary/5 text-xs font-semibold uppercase tracking-widest text-primary border-t border-primary/20">Social Media</td></tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Sponsor recognition / visibility</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
