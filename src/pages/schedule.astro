---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Schedule" description="The full schedule for the East of England Power Platform Summit 2026 - 1st & 2nd May 2026, Norwich.">
  <Hero
    title="Schedule"
    subtitle="Two days of Power Platform content in Norwich."
  />

  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4">

      <!-- Day 1 -->
      <div id="day1" class="mb-20">

        <!-- Day header -->
        <div class="flex items-center mb-8 gap-6">
          <div class="bg-primary text-white rounded-2xl px-6 py-4 text-center min-w-24 flex-shrink-0">
            <div class="text-xs font-bold text-white/80 uppercase tracking-widest">Friday</div>
            <div class="text-3xl font-extrabold leading-none my-1">1</div>
            <div class="text-xs text-white/80 uppercase tracking-widest">May</div>
          </div>
          <div>
            <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight">Day 1: Workshop Day</h2>
            <div class="flex flex-wrap items-center gap-4 text-text-light mt-2">
              <span class="flex items-center gap-1.5 text-sm">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                9:00 AM – 4:00 PM
              </span>
              <span class="flex items-center gap-1.5 text-sm">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Townshend House, 30 Crown Rd, Norwich NR1 3DT &bull;
                <a href="https://share.google/0XFQL3ShPVJXjfstT" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
                  Map<span class="sr-only"> (opens in new tab)</span>
                </a>
              </span>
            </div>
          </div>
        </div>

        <!-- Schedule card -->
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
          <div class="bg-primary/5 px-6 py-4 border-b border-border">
            <p class="text-text-light text-sm">
              Bring your laptop and get ready to build. Workshop details and speakers will be confirmed closer to the event.
            </p>
          </div>

          <div class="divide-y divide-border">

            <!-- Registration + Welcome (15 mins) -->
            <div class="flex items-start px-6 py-5 gap-6">
              <div class="w-16 flex-shrink-0 text-sm font-semibold text-text-light tabular-nums pt-0.5">09:00</div>
              <div class="flex-1">
                <span class="inline-block px-2.5 py-0.5 bg-gray-100 text-gray-600 text-xs font-medium rounded-full mb-2">Registration</span>
                <div class="font-semibold text-text">Registration &amp; Welcome</div>
                <div class="text-text-light text-sm mt-0.5">Arrive, grab a coffee, and get settled. Quick welcome from the team at 09:00.</div>
              </div>
              <div class="text-xs text-text-light flex-shrink-0 pt-0.5 tabular-nums">15 min</div>
            </div>

            <!-- Morning Workshop -->
            <div class="flex items-start px-6 py-5 gap-6">
              <div class="w-16 flex-shrink-0 text-sm font-semibold text-text-light tabular-nums pt-0.5">09:15</div>
              <div class="flex-1">
                <span class="inline-block px-2.5 py-0.5 bg-primary/10 text-primary text-xs font-medium rounded-full mb-2">Workshop</span>
                <div class="font-semibold text-text">Morning Workshop</div>
                <div class="text-text-light text-sm mt-0.5">Speaker and topic to be announced.</div>
              </div>
              <div class="text-xs text-text-light flex-shrink-0 pt-0.5 tabular-nums">3 hr 15 min</div>
            </div>

            <!-- Lunch -->
            <div class="flex items-start px-6 py-5 gap-6 bg-background-alt">
              <div class="w-16 flex-shrink-0 text-sm font-semibold text-text-light tabular-nums pt-0.5">12:30</div>
              <div class="flex-1">
                <span class="inline-block px-2.5 py-0.5 bg-secondary/15 text-secondary-dark text-xs font-medium rounded-full mb-2">Lunch</span>
                <div class="font-semibold text-text">Lunch &amp; Networking</div>
                <div class="text-text-light text-sm mt-0.5">Lunch provided. A great opportunity to connect with fellow attendees.</div>
              </div>
              <div class="text-xs text-text-light flex-shrink-0 pt-0.5 tabular-nums">1 hr</div>
            </div>

            <!-- Afternoon Workshop -->
            <div class="flex items-start px-6 py-5 gap-6">
              <div class="w-16 flex-shrink-0 text-sm font-semibold text-text-light tabular-nums pt-0.5">13:30</div>
              <div class="flex-1">
                <span class="inline-block px-2.5 py-0.5 bg-primary/10 text-primary text-xs font-medium rounded-full mb-2">Workshop</span>
                <div class="font-semibold text-text">Afternoon Workshop</div>
                <div class="text-text-light text-sm mt-0.5">Speaker and topic to be announced.</div>
              </div>
              <div class="text-xs text-text-light flex-shrink-0 pt-0.5 tabular-nums">2 hr 30 min</div>
            </div>

            <!-- Close -->
            <div class="flex items-start px-6 py-5 gap-6">
              <div class="w-16 flex-shrink-0 text-sm font-semibold text-text-light tabular-nums pt-0.5">16:00</div>
              <div class="flex-1">
                <span class="inline-block px-2.5 py-0.5 bg-gray-100 text-gray-600 text-xs font-medium rounded-full mb-2">Close</span>
                <div class="font-semibold text-text">Close</div>
                <div class="text-text-light text-sm mt-0.5">Wrap up and close. Venue closes at 4:30 PM.</div>
              </div>
            </div>

          </div>
        </div>
      </div>

      <!-- Day 2 -->
      <div id="day2">

        <!-- Day header -->
        <div class="flex items-center mb-8 gap-6">
          <div class="bg-accent text-white rounded-2xl px-6 py-4 text-center min-w-24 flex-shrink-0">
            <div class="text-xs font-bold text-white/80 uppercase tracking-widest">Saturday</div>
            <div class="text-3xl font-extrabold leading-none my-1">2</div>
            <div class="text-xs text-white/80 uppercase tracking-widest">May</div>
          </div>
          <div>
            <h2 class="text-3xl md:text-4xl font-extrabold text-text tracking-tight">Day 2: Conference Day</h2>
            <div class="flex flex-wrap items-center gap-4 text-text-light mt-2">
              <span class="flex items-center gap-1.5 text-sm">
                <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                8:00 AM – 5:30 PM
              </span>
              <span class="flex items-center gap-1.5 text-sm">
                <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                The Space, Norwich &bull;
                <a href="https://maps.app.goo.gl/yZwjpQounUmR1Hz7A" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
                  Map<span class="sr-only"> (opens in new tab)</span>
                </a>
              </span>
            </div>
          </div>
        </div>

        <!-- Sessionize embed -->
        <link rel="stylesheet" href="https://sessionize.com/api/v2/9q20ek5l/embedstyle" />
        <div class="sessionize-embed mt-6">
          <script is:inline src="https://sessionize.com/api/v2/9q20ek5l/view/GridSmart"></script>
        </div>
      </div>

    </div>
  </section>

  <!-- Modal container required by Sessionize -->
  <div id="sz-modal-container" class="is-hidden"></div>

  <!-- CTA -->
  <section class="relative py-16 bg-primary text-white overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-secondary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="relative container mx-auto px-4 text-center">
      <h2 class="text-3xl font-extrabold mb-3 tracking-tight">Stay Up to Date</h2>
      <p class="text-white/80 mb-8 max-w-xl mx-auto">
        Follow us on LinkedIn for speaker announcements and event updates.
      </p>
      <a
        href="https://www.linkedin.com/company/eoepps/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-secondary text-gray-900 px-8 py-3.5 rounded-xl font-bold text-lg hover:bg-secondary-light hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 shadow-lg"
      >
        Follow on LinkedIn<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>
  </section>
</BaseLayout>
