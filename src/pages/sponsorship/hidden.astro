                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
              </tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Logo size on rotating sponsor slides</td>
                <td class="py-3 text-center text-text text-xs font-semibold">Grouped</td>
                <td class="py-3 text-center text-text text-xs font-semibold">Standard</td>
                <td class="py-3 text-center text-text text-xs font-semibold">Prominent</td>
                <td class="py-3 text-center text-text text-xs font-semibold">Featured</td>
                <td class="py-3 text-center text-text text-xs font-semibold">Headline</td>
              </tr>

              <tr><td colspan="6" class="py-2 px-5 bg-primary/5 text-xs font-semibold uppercase tracking-widest text-primary border-t border-primary/20">Expo Hall</td></tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Expo hall presence</td>
                <td class="py-3 text-center text-text-light/40 font-bold text-base">✘</td>
