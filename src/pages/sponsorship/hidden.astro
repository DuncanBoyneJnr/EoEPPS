                  <div class="text-xl font-bold">£750</div>
                </th>
                <th class="py-5 px-3 bg-gray-600 text-white font-semibold text-center border-b border-gray-500 w-24">
                  <div class="text-white/70 text-xs uppercase tracking-wider mb-1">Silver</div>
                  <div class="text-xl font-bold">£1,500</div>
                </th>
                <th class="py-5 px-3 bg-secondary text-gray-900 font-semibold text-center border-b border-secondary/50 w-24">
                  <div class="text-gray-700 text-xs uppercase tracking-wider mb-1">Gold</div>
                  <div class="text-xl font-bold">£3,000</div>
                </th>
                <th class="py-5 px-3 bg-gradient-to-b from-primary to-accent text-white font-semibold text-center border-b border-primary/20 w-24">
                  <div class="text-white/70 text-xs uppercase tracking-wider mb-1">Platinum</div>
                  <div class="text-xl font-bold">£5,000</div>
                </th>
              </tr>
            </thead>
            <tbody>
              <tr><td colspan="6" class="py-2 px-5 bg-primary/5 text-xs font-semibold uppercase tracking-widest text-primary border-t border-primary/20">Brand &amp; Logo</td></tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
                <td class="py-3 px-5 text-text-light">Website logo placement</td>
                <td class="py-3 text-center text-text text-xs font-semibold">Grouped<br/>panel</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
                <td class="py-3 text-center text-green-600 font-bold text-base">✔</td>
