---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="2027 Sponsors" description="The organisations backing East of England Power Platform Summit 2027 — supporting the Power Platform community across the East of England.">
  <Hero
    title="2027 Sponsors"
    subtitle="The organisations making EoEPPS 2027 possible."
  />

  <section class="py-16">
    <div class="container mx-auto px-4">

      <div class="max-w-2xl mx-auto bg-primary/5 border border-primary/20 rounded-2xl p-10 text-center mb-12">
        <p class="text-text-light text-lg mb-6 leading-relaxed">More sponsors to be announced. If you'd like your organisation listed here, get in touch about our 2027 packages.</p>
        <a
          href="mailto:info@eoepps.co.uk?subject=Sponsorship%20Enquiry%20-%20EoEPPS%202027"
          class="inline-block bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-primary-dark transition-colors"
        >
          Become a 2027 Sponsor
        </a>
      </div>

      <div class="text-center">
        <p class="text-text-light mb-4">Looking for our 2026 sponsors?</p>
        <a
          href="/sponsors/2026"
          class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors"
        >
          View 2026 Sponsors
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Sponsor CTA -->
  <section class="py-16 bg-gradient-to-br from-primary to-accent text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Support the East of England Power Platform Community</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Sponsoring EoEPPS puts your brand in front of Power Platform professionals from across the region.
      </p>
      <a
        href="/sponsorship"
        class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition-colors"
      >
        View 2027 Packages
      </a>
    </div>
  </section>
</BaseLayout>
