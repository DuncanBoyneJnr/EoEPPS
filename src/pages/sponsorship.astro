---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Become a Sponsor" description="Sponsor EoEPPS 2027 and put your brand in front of Power Platform professionals, developers, and decision-makers from across the East of England. Packages coming soon.">
  <Hero
    title="Become a Sponsor"
    subtitle="Partner with the East of England Power Platform community."
  />

  <!-- Why Sponsor -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-text mb-8 text-center">Why Sponsor EoEPPS?</h2>

        <div class="grid md:grid-cols-2 gap-6 mb-12">
          <div class="flex items-start">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-text mb-1">Promote Your Brand</h3>
              <p class="text-text-light">Reach a targeted audience of Power Platform professionals, decision-makers, and innovators from across the East of England.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-text mb-1">Showcase Your Expertise</h3>
              <p class="text-text-light">Position your brand at the centre of the East of England's fast-growing Microsoft Power Platform ecosystem.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-text mb-1">Support the Community</h3>
              <p class="text-text-light">Demonstrate your commitment to the local tech community. EoEPPS is built by volunteers — your sponsorship is what makes it possible.</p>
            </div>
          </div>

          <div class="flex items-start">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-text mb-1">Network Directly</h3>
              <p class="text-text-light">Exhibition stands on Day 2 give you direct access to attendees. Meet potential clients, partners, and candidates face-to-face.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Reach Stats -->
  <section class="py-16 bg-gradient-to-br from-primary to-accent text-white">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold mb-12 text-center">Who You'll Reach</h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-4 bg-white/20 rounded-full flex items-center justify-center">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">The Audience</h3>
          <ul class="text-white/90 space-y-2 text-sm">
            <li>Power Platform professionals from across the East of England</li>
            <li>Developers, analysts, and IT decision-makers</li>
            <li>Two full days of direct engagement</li>
          </ul>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-4 bg-white/20 rounded-full flex items-center justify-center">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">On the Day</h3>
          <ul class="text-white/90 space-y-2 text-sm">
            <li>Exhibition area at The Space on Day 2</li>
            <li>Your logo on all event slides throughout both days</li>
            <li>Verbal recognition in opening and closing remarks</li>
          </ul>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-4 bg-white/20 rounded-full flex items-center justify-center">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Beyond the Event</h3>
          <ul class="text-white/90 space-y-2 text-sm">
            <li>Your logo on the EoEPPS website throughout the event year</li>
            <li>Social media promotion to the NPPUG community and beyond</li>
            <li>Association with the East of England's premier Power Platform event</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsorship Packages -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-text mb-4">2027 Sponsorship Packages</h2>
        <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-6" aria-hidden="true"></div>
      </div>

      <div class="max-w-2xl mx-auto bg-primary/5 border border-primary/20 rounded-2xl p-10 text-center">
        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-text mb-3">Packages Coming Soon</h3>
        <p class="text-text-light text-lg mb-8 leading-relaxed">
          2027 sponsorship packages are coming soon. If you'd like to express early interest in sponsoring EoEPPS 2027, get in touch and we'll reach out when packages are ready.
        </p>
        <a
          href="mailto:info@eoepps.co.uk?subject=Sponsorship%20Enquiry%20-%20EoEPPS%202027"
          class="inline-block bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-primary-dark transition-colors"
        >
          Express Interest
        </a>
      </div>
    </div>
  </section>

  <!-- 2026 Sponsors -->
  <section class="py-16 bg-background-alt">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold text-text mb-4">2026 Sponsors</h2>
      <p class="text-text-light text-lg mb-8">Thank you to everyone who supported EoEPPS 2026.</p>
      <a
        href="/sponsors"
        class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors"
      >
        View 2026 Sponsors
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
