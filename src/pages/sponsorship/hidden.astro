              <tr><td colspan="6" class="py-2 px-5 bg-primary/5 text-xs font-semibold uppercase tracking-widest text-primary border-t border-primary/20">Sponsored Session</td></tr>
              <tr class="border-t border-primary/10 hover:bg-primary/5 transition-colors">
