---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
---

<BaseLayout title="Speakers" description="Meet the speakers at the East of England Power Platform Summit 2026.">
  <Hero
    title="Speakers"
    subtitle="Inspiring voices from the Power Platform community."
  />

  <!-- Keynote Speaker -->
  <section class="py-16 bg-gradient-to-br from-primary via-primary-dark to-accent text-white">
    <div class="container mx-auto px-4 text-center">
      <p class="text-secondary font-bold uppercase tracking-widest text-sm mb-6">Keynote Speaker</p>
      <img
        src="/images/speakers/chris-huntingford.jpg"
        alt="Chris Huntingford"
        class="w-40 h-40 rounded-full object-cover border-4 border-secondary shadow-2xl mx-auto mb-6"
      />
      <h2 class="text-4xl md:text-5xl font-bold mb-6">Chris Huntingford</h2>
      <div class="flex items-center gap-6 justify-center">
        <a href="https://www.chrishuntingford.com/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
          chrishuntingford.com
        </a>
        <a href="https://www.linkedin.com/in/chrishuntingford/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- Conference Speakers (Sessionize SpeakerWall) -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text mb-4">Conference Speakers</h2>
        <p class="text-text-light text-lg max-w-2xl mx-auto">
          Click any speaker to learn more about them and see which sessions they're presenting.
        </p>
      </div>
      <link rel="stylesheet" href="https://sessionize.com/api/v2/9q20ek5l/embedstyle" />
      <script is:inline src="https://sessionize.com/api/v2/9q20ek5l/view/SpeakerWall"></script>
    </div>
  </section>

  <!-- Modal container required by Sessionize -->
  <div id="sz-modal-container" class="is-hidden"></div>

  <!-- View Schedule CTA -->
  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Plan Your Day?</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        View the full schedule to see when each session is on and which tracks to choose from.
      </p>
      <a
        href="/schedule"
        class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition-colors"
      >
        View the Schedule
      </a>
    </div>
  </section>
</BaseLayout>
