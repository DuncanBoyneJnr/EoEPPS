---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Override the canonical URL (defaults to current page URL) */
  canonical?: string;
  /** Set to false to exclude from sitemaps / search (e.g. thank-you pages) */
  noindex?: boolean;
  /** OG image override – must be an absolute URL */
  ogImage?: string;
  /** Page type for structured data context */
  pageType?: 'website' | 'article';
}

const {
  title,
  description = 'East of England Power Platform Summit 2026 — 1st & 2nd May 2026, Norwich, Norfolk. Free to attend on the conference day. Power Apps, Power Automate, Power BI, Copilot Studio.',
  canonical = Astro.url.href,
  noindex = false,
  ogImage = 'https://eoepps.co.uk/images/og-card.png',
  pageType = 'website',
} = Astro.props;

const siteName = 'East of England Power Platform Summit 2026';
const fullTitle = title === 'Home' ? siteName : `${title} | ${siteName}`;

// BreadcrumbList — only rendered on inner pages
const isHomepage = Astro.url.pathname === '/';
const breadcrumbSchema = !isHomepage ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://eoepps.co.uk',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: canonical,
    },
  ],
} : null;

// Event JSON-LD — present on every page so Google always has the event context
const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'East of England Power Platform Summit 2026',
  alternateName: 'EoEPPS 2026',
  description: 'The East of England\'s inaugural Power Platform Summit — two days of hands-on workshops and expert conference sessions covering Power Apps, Power Automate, Power BI, and Copilot Studio.',
  url: 'https://eoepps.co.uk',
  startDate: '2026-05-01',
  endDate: '2026-05-02',
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  isAccessibleForFree: true,
  inLanguage: 'en-GB',
  location: [
    {
      '@type': 'Place',
      name: 'Townshend House',
      description: 'Workshop Day (Friday 1 May)',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Townshend House, Townshend Road',
        addressLocality: 'Norwich',
        addressRegion: 'Norfolk',
        postalCode: 'NR2 2AF',
        addressCountry: 'GB',
      },
    },
    {
      '@type': 'Place',
      name: 'The Space',
      description: 'Conference Day (Saturday 2 May)',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'The Space, Duke Street',
        addressLocality: 'Norwich',
        addressRegion: 'Norfolk',
        postalCode: 'NR3 3AP',
        addressCountry: 'GB',
      },
    },
  ],
  organizer: {
    '@type': 'Organization',
    name: 'Norfolk Power Platform User Group',
    url: 'https://www.nppug.co.uk',
  },
  image: 'https://eoepps.co.uk/images/Logo.png',
  keywords: 'Power Platform, Power Apps, Power Automate, Power BI, Copilot Studio, Microsoft, low-code, Norwich, Norfolk, East of England, conference, summit, 2026',
};
---

<!DOCTYPE html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/Logo.png" />
    <link rel="preload" as="image" href="/images/Logo.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={pageType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteName} — Norwich, 1–2 May 2026`} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@eoepps" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${siteName} — Norwich, 1–2 May 2026`} />

    <title>{fullTitle}</title>

    <!-- Event JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(eventSchema)} />

    <!-- BreadcrumbList (inner pages only) -->
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}

    <!-- Umami Analytics -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="9a32fa67-717f-4e5e-a855-ee5ddb7dda91"></script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-450M6BYX75"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-450M6BYX75');
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content" class="flex-grow" role="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
