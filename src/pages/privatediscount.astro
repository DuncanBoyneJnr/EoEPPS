---
import BaseLayout from '../layouts/BaseLayout.astro';

const BOOKING_URL = 'https://eoeppstickets.netlify.app/discount-checkout?priceId=price_1TCij79Vyui5TaHDeo0TUHmv';
---

<BaseLayout
  title="Exclusive Workshop Offer"
  description="Exclusive discounted booking for From Canvas to Code Apps: Your Next Step (It's Easier Than You Think) at EoEPPS 2026."
  noindex={true}
>
  <!-- Hero -->
  <div class="bg-gradient-to-br from-primary via-primary-dark to-accent text-white py-20 px-4">
    <div class="container mx-auto max-w-3xl text-center">
      <span class="inline-block bg-secondary text-gray-900 text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full mb-6">
        Exclusive Offer
      </span>
      <h1 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
        From Canvas to Code Apps:<br class="hidden md:block" />
        Your Next Step<br class="hidden md:block" />
        <span class="text-secondary">(It's Easier Than You Think)</span>
      </h1>
      <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10">
        You've been sent a special discounted link to book this workshop at EoEPPS 2026. Places are limited — secure yours now.
      </p>
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-secondary text-gray-900 font-bold text-lg px-10 py-4 rounded-xl hover:bg-secondary/90 transition-colors shadow-lg"
      >
        Book My Place<span class="sr-only"> (opens in new tab)</span>
      </a>
    </div>
  </div>

  <!-- Workshop details -->
  <section class="py-16 bg-background-alt">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-2xl font-bold text-text mb-6">About This Workshop</h2>

      <div class="bg-white rounded-xl shadow-sm border border-border p-8 space-y-6 text-text-light leading-relaxed">
        <p>
          This hands-on workshop is designed for Power Platform makers who are ready to take their skills to the next level. You'll discover how easy it is to move from canvas apps into full code-first approaches — and why the leap is smaller than you think.
        </p>

        <div class="grid sm:grid-cols-3 gap-4 pt-2">
          <div class="bg-background-alt rounded-lg p-4 text-center">
            <div class="text-sm font-semibold text-text uppercase tracking-wide mb-1">Date</div>
            <div class="text-text font-medium">Friday 1 May 2026</div>
          </div>
          <div class="bg-background-alt rounded-lg p-4 text-center">
            <div class="text-sm font-semibold text-text uppercase tracking-wide mb-1">Location</div>
            <div class="text-text font-medium">Townshend House, Norwich</div>
          </div>
          <div class="bg-background-alt rounded-lg p-4 text-center">
            <div class="text-sm font-semibold text-text uppercase tracking-wide mb-1">Format</div>
            <div class="text-text font-medium">Hands-on Workshop</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16">
    <div class="container mx-auto px-4 max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-text mb-4">Ready to Book?</h2>
      <p class="text-text-light mb-8">
        Your exclusive discount is applied automatically. Click below to complete your booking through our secure ticketing system.
      </p>
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-primary text-white font-bold text-lg px-10 py-4 rounded-xl hover:bg-primary-dark transition-colors shadow-md"
      >
        Book My Place Now<span class="sr-only"> (opens in new tab)</span>
      </a>
      <p class="text-sm text-text-light mt-6">
        Questions? Email <a href="mailto:info@eoepps.co.uk" class="text-primary hover:text-primary-dark font-medium">info@eoepps.co.uk</a>
      </p>
    </div>
  </section>
</BaseLayout>
