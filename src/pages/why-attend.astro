---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Why Attend"
  description="Discover why EoEPPS is the must-attend Power Platform event for the East of England — hands-on learning, expert speakers, community, and it's free to attend."
>
  <Hero
    title="Why Attend EoEPPS?"
    subtitle="Two days of learning, building, and connecting — with the Power Platform community right on your doorstep."
    showCta={true}
    ctaText="Get Your Ticket"
    ctaLink="https://eoeppstickets.netlify.app"
    secondaryCta="View the Programme"
    secondaryCtaLink="/sessions"
  />

  <!-- Top reasons grid -->
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center mb-14">
        <h2 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">Six reasons not to miss it</h2>
        <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-6" aria-hidden="true"></div>
        <p class="text-lg text-text-light max-w-2xl mx-auto leading-relaxed">
          Whether you're brand new to Power Platform or have years of experience, EoEPPS has something genuinely valuable for you.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">

        <!-- Reason 1 -->
        <div class="reason-card bg-white rounded-2xl shadow-md p-7">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-3">Learn from real practitioners</h3>
          <p class="text-text-light leading-relaxed">
            Every session is delivered by someone who works with Power Platform day-to-day in real organisations. No marketing fluff — just practical knowledge you can apply on Monday morning.
          </p>
        </div>

        <!-- Reason 2 -->
        <div class="reason-card bg-white rounded-2xl shadow-md p-7">
          <div class="w-12 h-12 rounded-xl bg-secondary/20 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-3">Build your network</h3>
          <p class="text-text-light leading-relaxed">
            Connect with hundreds of Power Platform professionals from across the East of England and beyond. These are the people who will answer your questions, share opportunities, and become long-term collaborators.
          </p>
        </div>

        <!-- Reason 3 -->
        <div class="reason-card bg-white rounded-2xl shadow-md p-7">
          <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-3">Hands-on workshops</h3>
          <p class="text-text-light leading-relaxed">
            Day 1 is a full day of immersive, instructor-led workshops. You won't just watch — you'll build something real. Choose the session that fits your level and walk away with working code and new skills.
          </p>
        </div>

        <!-- Reason 4 -->
        <div class="reason-card bg-white rounded-2xl shadow-md p-7">
          <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-3">Free to attend (conference day)</h3>
          <p class="text-text-light leading-relaxed">
            The Saturday conference is completely free. No catch, no paywall. EoEPPS is a community event run by volunteers — we believe access to quality learning shouldn't cost you anything.
          </p>
        </div>

        <!-- Reason 5 -->
        <div class="reason-card bg-white rounded-2xl shadow-md p-7">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-3">Right here in the East of England</h3>
          <p class="text-text-light leading-relaxed">
            World-class Power Platform content without the London price tag or travel cost. The venue is in central Norwich, easily reached by road or rail from across Norfolk, Suffolk, Cambridgeshire, and beyond.
          </p>
        </div>

        <!-- Reason 6 -->
        <div class="reason-card bg-white rounded-2xl shadow-md p-7">
          <div class="w-12 h-12 rounded-xl bg-secondary/20 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-6 h-6 text-secondary-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-text mb-3">A genuinely welcoming community</h3>
          <p class="text-text-light leading-relaxed">
            EoEPPS grows from the NPPUG community — known for being friendly, inclusive, and supportive. You won't feel like an outsider. Everyone's here to learn and share, whatever their background.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Who is it for -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-primary/5 to-accent/5">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
          <h2 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">Who should come?</h2>
          <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-6" aria-hidden="true"></div>
          <p class="text-lg text-text-light max-w-2xl mx-auto leading-relaxed">
            EoEPPS is designed to be useful at every level. Here's how different attendees benefit.
          </p>
        </div>

        <div class="space-y-4">

          <details class="persona-item bg-white rounded-2xl shadow-sm overflow-hidden group">
            <summary class="flex items-center gap-4 p-6 cursor-pointer select-none list-none">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text flex-1">I'm new to Power Platform</h3>
              <svg class="w-5 h-5 text-text-light transition-transform duration-200 group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-light leading-relaxed border-t border-gray-100 pt-4">
              <p class="mb-3">EoEPPS is one of the best places to start. You'll find introductory sessions pitched at beginners, a workshop day where you build something guided step-by-step, and a community of experienced practitioners who are happy to answer questions and point you in the right direction.</p>
              <p>You'll leave with a clearer picture of what Power Platform can do, where to focus your learning, and contacts who can help you along the way.</p>
            </div>
          </details>

          <details class="persona-item bg-white rounded-2xl shadow-sm overflow-hidden group">
            <summary class="flex items-center gap-4 p-6 cursor-pointer select-none list-none">
              <div class="w-10 h-10 rounded-full bg-secondary/20 flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-5 h-5 text-secondary-dark" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text flex-1">I'm an experienced Power Platform professional</h3>
              <svg class="w-5 h-5 text-text-light transition-transform duration-200 group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-light leading-relaxed border-t border-gray-100 pt-4">
              <p class="mb-3">There are advanced sessions, deep-dives, and workshops designed for people who already know their way around the platform. You'll encounter techniques you haven't seen before, and be challenged to go further.</p>
              <p>Beyond the content, you'll meet peers at your level who face the same challenges you do — and the connections you make here have a way of turning into collaborations, job opportunities, and friendships.</p>
            </div>
          </details>

          <details class="persona-item bg-white rounded-2xl shadow-sm overflow-hidden group">
            <summary class="flex items-center gap-4 p-6 cursor-pointer select-none list-none">
              <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h8a2 2 0 012 2v12a1 1 0 110 2h-3a1 1 0 01-1-1v-2a1 1 0 00-1-1H9a1 1 0 00-1 1v2a1 1 0 01-1 1H4a1 1 0 110-2V4zm3 1h2v2H7V5zm2 4H7v2h2V9zm2-4h2v2h-2V5zm2 4h-2v2h2V9z" clip-rule="evenodd"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text flex-1">I'm a business analyst, IT manager, or decision-maker</h3>
              <svg class="w-5 h-5 text-text-light transition-transform duration-200 group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-light leading-relaxed border-t border-gray-100 pt-4">
              <p class="mb-3">EoEPPS will give you a clear, unbiased view of what Power Platform can realistically deliver for your organisation — shown through real case studies from people who've shipped it, not sales pitches from vendors.</p>
              <p>You'll be able to see the platform in action, ask candid questions, and meet the kind of consultants and developers who could help you if you decided to move forward.</p>
            </div>
          </details>

          <details class="persona-item bg-white rounded-2xl shadow-sm overflow-hidden group">
            <summary class="flex items-center gap-4 p-6 cursor-pointer select-none list-none">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text flex-1">I'm a student or career-changer</h3>
              <svg class="w-5 h-5 text-text-light transition-transform duration-200 group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <div class="px-6 pb-6 text-text-light leading-relaxed border-t border-gray-100 pt-4">
              <p class="mb-3">The Microsoft Power Platform ecosystem is one of the fastest-growing areas in tech, and EoEPPS is a brilliant way to fast-track your understanding of what the market actually needs and how organisations are using these tools right now.</p>
              <p>Attending puts you in a room with hiring managers, consultants, and developers who actively look for motivated newcomers. Bring your questions — and your business cards.</p>
            </div>
          </details>

        </div>
      </div>
    </div>
  </section>

  <!-- What you'll take away -->
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-text mb-4 tracking-tight">What you'll take away</h2>
            <div class="w-14 h-1.5 bg-secondary rounded-full mb-8" aria-hidden="true"></div>
            <p class="text-lg text-text-light mb-8 leading-relaxed">
              EoEPPS is designed to send you home with more than just a lanyard. Here's what attendees consistently find most valuable.
            </p>
            <ul class="space-y-4">
              {[
                { label: 'Practical skills', desc: 'Techniques and patterns you can implement immediately — whether from a workshop or a conference session.' },
                { label: 'New connections', desc: 'A network of peers, mentors, and potential collaborators you simply don\'t find at online events.' },
                { label: 'Industry perspective', desc: 'A clearer view of where Power Platform is heading and how others are solving problems similar to yours.' },
                { label: 'Confidence', desc: 'Seeing others at your level sharing their work is one of the most motivating things you can experience.' },
                { label: 'Resources', desc: 'Slides, repos, and follow-up content from every session — made available to all attendees after the event.' },
              ].map(item => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-text-light"><strong class="text-text">{item.label}</strong> — {item.desc}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Day format cards -->
          <div class="space-y-5">
            <div class="day-card bg-white rounded-2xl shadow-md p-7 border-l-4 border-primary">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-block bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Day 1 — Friday 1 May</span>
              </div>
              <h3 class="text-xl font-bold text-text mb-2">Workshop Day</h3>
              <p class="text-text-light leading-relaxed mb-4">The Digital Hub, Townshend House, Norwich</p>
              <ul class="space-y-2 text-text-light text-sm">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>Full-day, hands-on, instructor-led workshops</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>Multiple tracks across experience levels</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>Paid ticket required (limited places)</span>
                </li>
              </ul>
            </div>

            <div class="day-card bg-white rounded-2xl shadow-md p-7 border-l-4 border-secondary-dark">
              <div class="flex items-center gap-3 mb-4">
                <span class="inline-block bg-secondary text-gray-900 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Day 2 — Saturday 2 May</span>
              </div>
              <h3 class="text-xl font-bold text-text mb-2">Conference Day</h3>
              <p class="text-text-light leading-relaxed mb-4">The Digital Hub, Townshend House, Norwich</p>
              <ul class="space-y-2 text-text-light text-sm">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-secondary-dark mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>Full conference programme with parallel tracks</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-secondary-dark mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>Keynote, sponsor exhibition, and networking</span>
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 text-secondary-dark mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span>Completely free to attend</span>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 bg-gradient-to-br from-primary/5 to-accent/5">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-5xl font-extrabold text-primary mb-2 tracking-tight">2</div>
          <div class="text-text-light font-medium text-sm">Full Days</div>
        </div>
        <div>
          <div class="text-5xl font-extrabold text-primary mb-2 tracking-tight">Free</div>
          <div class="text-text-light font-medium text-sm">Conference Day</div>
        </div>
        <div>
          <div class="text-5xl font-extrabold text-primary mb-2 tracking-tight">Norwich</div>
          <div class="text-text-light font-medium text-sm">City Centre Venues</div>
        </div>
        <div>
          <div class="text-5xl font-extrabold text-primary mb-2 tracking-tight">1–2 May</div>
          <div class="text-text-light font-medium text-sm">2026</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 md:py-28 bg-primary text-white overflow-hidden">
    <div class="absolute -top-32 -right-32 w-96 h-96 rounded-full bg-secondary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full bg-accent/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="relative container mx-auto px-4 text-center">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">Ready to join us?</h2>
      <div class="w-14 h-1.5 bg-secondary rounded-full mx-auto mb-6" aria-hidden="true"></div>
