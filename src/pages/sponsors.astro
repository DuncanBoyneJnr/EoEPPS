---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout title="Our Sponsors" description="The organisations and businesses sponsoring the East of England Power Platform Summit 2026 — supporting the Power Platform community in Norwich, Norfolk, and the wider East of England.">
  <Hero
    title="Our Sponsors"
    subtitle="Thank you to the organisations making EoEPPS possible."
  />

  <!-- Current Sponsors -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-text mb-8 text-center">Current Sponsors</h2>

      <!-- Gold Sponsors -->
      <div class="mb-4 text-center">
        <span class="inline-block bg-secondary text-gray-900 font-bold text-sm px-4 py-1 rounded-full uppercase tracking-wide">Gold Sponsor</span>
      </div>
      <div class="max-w-xl mx-auto mb-16">
        <div class="sponsor-card-gold bg-white rounded-xl shadow-md border-2 border-secondary p-8 text-center">
          <div class="h-24 flex items-center justify-center mb-6 bg-[#1e2235] rounded-lg px-6">
            <img src="/images/sponsors/GTP-Tech.png" alt="GTP Tech Recruitment" width="758" height="300" loading="lazy" class="max-h-full max-w-full object-contain" />
          </div>
          <p class="font-bold text-text text-xl mb-2">GTP Tech Recruitment</p>
          <p class="text-text-light mb-6">
            Specialist technology recruitment connecting exceptional tech talent with leading organisations across the UK.
          </p>
          <a
            href="https://gtptech.co.uk/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-secondary text-gray-900 px-6 py-2.5 rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            Visit gtptech.co.uk<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>
      </div>

      <!-- Community Sponsors -->
      <div class="mb-4 text-center">
        <span class="inline-block bg-secondary text-gray-900 font-bold text-sm px-4 py-1 rounded-full uppercase tracking-wide">Community Sponsors</span>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-16">
        <div class="sponsor-card-community bg-white rounded-xl shadow-md border border-gray-200 p-8 text-center flex flex-col">
          <div class="h-20 flex items-center justify-center mb-6">
            <img src="/images/sponsors/Powercademy.png" alt="Powercademy" width="613" height="196" loading="lazy" class="max-h-full max-w-full object-contain" />
          </div>
          <p class="font-bold text-text text-xl mb-2">Powercademy</p>
          <p class="text-text-light mb-6 flex-1">
            The Power Platform's Only Platform — practical, hands-on Power Platform, Copilot, and AI training for all skill levels.
          </p>
          <a
            href="https://www.powercademy.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-secondary text-gray-900 px-6 py-2.5 rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            Visit powercademy.com<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>

        <div class="sponsor-card-community bg-white rounded-xl shadow-md border border-gray-200 p-8 text-center flex flex-col">
          <div class="h-20 flex items-center justify-center mb-6">
            <img src="/images/sponsors/PowerPagesMastery.png" alt="Power Pages Mastery" width="800" height="200" loading="lazy" class="max-h-full max-w-full object-contain" />
          </div>
          <p class="font-bold text-text text-xl mb-2">Power Pages Mastery</p>
          <p class="text-text-light mb-6 flex-1">
            A structured programme teaching Power Platform professionals how to deliver customer-facing portal projects with confidence — covering architecture, security, data modelling, and advanced customisation.
          </p>
          <a
            href="https://francomusso.com/power-pages-course"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-secondary text-gray-900 px-6 py-2.5 rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            Learn more<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>

        <div class="sponsor-card-community bg-white rounded-xl shadow-md border border-gray-200 p-8 text-center flex flex-col">
          <div class="h-20 flex items-center justify-center mb-6">
            <img src="/images/sponsors/ExtraLife.png" alt="Extra Life" width="800" height="200" loading="lazy" class="max-h-full max-w-full object-contain" />
          </div>
          <p class="font-bold text-text text-xl mb-2">Extra Life</p>
          <p class="text-text-light mb-6 flex-1">
            The ultimate freelancing course for Power Platform professionals — practical strategies for building a sustainable independent consultancy, attracting clients, and maintaining work-life balance.
          </p>
          <a
            href="https://francomusso.com/extralife"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-secondary text-gray-900 px-6 py-2.5 rounded-lg font-semibold hover:opacity-90 transition-opacity"
          >
            Learn more<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>

        <div class="sponsor-card-community bg-white rounded-xl shadow-md border border-gray-200 p-8 flex flex-col md:col-span-3">
          <div class="flex flex-col lg:flex-row gap-8 items-start">
            <div class="flex flex-col items-center text-center lg:items-start lg:text-left flex-shrink-0 lg:w-64">
              <div class="h-20 w-full flex items-center justify-center mb-6 bg-[#0d1b35] rounded-lg px-4">
                <img src="/images/sponsors/Untethered365.png" alt="Untethered 365" width="800" height="200" loading="lazy" class="max-h-full max-w-full object-contain" />
              </div>
              <p class="font-bold text-text text-xl mb-2">Untethered 365</p>
              <p class="text-text-light mb-6">
                Want AI to replace 95% of your tasks instead of 100% of you? Join their free 5-day live training on Extremely Accurate AI &amp; Architecture — and stay ahead of the curve.
              </p>
              <a
                href="https://www.untethered365.com/freetraining?utm_source=conference&utm_medium=conference&utm_content=norfolk-summit"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block bg-secondary text-gray-900 px-6 py-2.5 rounded-lg font-semibold hover:opacity-90 transition-opacity"
              >
                Join free training<span class="sr-only"> (opens in new tab)</span>
              </a>
            </div>
            <div class="w-full">
              <div class="relative w-full" style="padding-bottom: 56.25%;">
                <iframe
                  class="absolute inset-0 w-full h-full rounded-xl shadow-md"
                  src="https://www.youtube.com/embed/mAfnViTfPkQ"
                  title="Untethered 365 — free AI training"
allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center">
        <p class="text-text-light text-lg mb-6">Interested in becoming a sponsor?</p>
        <a href="/sponsorship" class="inline-block bg-primary text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-primary-dark transition-colors">
          View Sponsorship Packages
        </a>
      </div>
    </div>
  </section>

  <!-- Why Sponsor CTA -->
  <section class="py-16 bg-gradient-to-br from-primary to-accent text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Support the East of England Power Platform Community</h2>
      <p class="text-xl text-white/90 mb-8 max-w-2xl mx-auto">
        Sponsoring EoEPPS puts your brand in front of Power Platform professionals from across the region.
      </p>
      <a
        href="/sponsorship"
        class="inline-block bg-white text-primary px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition-colors"
      >
        Become a Sponsor
      </a>
    </div>
  </section>
</BaseLayout>

<style>
.sponsor-card-gold {
    border-top: 4px solid #FBBF24;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .sponsor-card-gold:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px -4px rgba(251, 191, 36, 0.3), 0 4px 12px -2px rgba(0, 0, 0, 0.08);
  }
  .sponsor-card-community {
    border-top: 4px solid transparent;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-top-color 0.2s ease;
  }
  .sponsor-card-community:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px -4px rgba(251, 191, 36, 0.25), 0 4px 12px -2px rgba(0, 0, 0, 0.08);
    border-top-color: #FBBF24;
  }
</style>
